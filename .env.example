# Telegram Bot Token — get one from @BotFather on Telegram
TELETHINGS_TELEGRAM_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Comma-separated Telegram user IDs allowed to use the bot
# Tip: message @userinfobot on Telegram to find your user ID
TELETHINGS_ALLOWED_USER_IDS=123456789,987654321

# Optional: SQLite database DSN (default: $XDG_DATA_HOME/telethings/telethings.db,
# typically ~/.local/share/telethings/telethings.db — created automatically)
# TELETHINGS_DB_DSN=file:/home/you/.local/share/telethings/telethings.db
